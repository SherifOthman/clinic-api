@baseUrl = http://localhost:5000
@contentType = application/json
@branchId = 00000000-0000-0000-0000-000000000001

# ─────────────────────────────────────────────────────────────────────────────
# BRANCHES
# ─────────────────────────────────────────────────────────────────────────────

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "emailOrUsername": "owner@clinic.com",
  "password": "Password123!"
}

@token = {{login.response.body.$.accessToken}}

### Get all branches
GET {{baseUrl}}/api/branches
Authorization: Bearer {{token}}

### Create a branch
# CreateBranchCommand: Name, AddressLine, StateGeonameId?, CityGeonameId?, PhoneNumbers
POST {{baseUrl}}/api/branches
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Main Branch",
  "addressLine": "123 King Fahd Road, Riyadh",
  "stateGeonameId": 101628,
  "cityGeonameId": 108410,
  "phoneNumbers": ["+966112345678"]
}

### Create branch (minimal — no location)
POST {{baseUrl}}/api/branches
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Downtown Branch",
  "addressLine": "456 Olaya Street",
  "stateGeonameId": null,
  "cityGeonameId": null,
  "phoneNumbers": []
}

### Update a branch
# UpdateBranchCommand: Name, AddressLine, StateGeonameId?, CityGeonameId?, PhoneNumbers
PUT {{baseUrl}}/api/branches/{{branchId}}
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "name": "Main Branch (Updated)",
  "addressLine": "789 Prince Sultan Road",
  "stateGeonameId": 101628,
  "cityGeonameId": 108410,
  "phoneNumbers": ["+966112345678", "+966119876543"]
}

### Deactivate a branch
# SetBranchActiveStatusCommand: IsActive
PATCH {{baseUrl}}/api/branches/{{branchId}}/active-status
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "isActive": false
}

### Activate a branch
PATCH {{baseUrl}}/api/branches/{{branchId}}/active-status
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "isActive": true
}
