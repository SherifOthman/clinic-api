@baseUrl = http://localhost:5000
@contentType = application/json
@staffId = 00000000-0000-0000-0000-000000000001
@invitationId = 00000000-0000-0000-0000-000000000002
@branchId = 00000000-0000-0000-0000-000000000003
@visitTypeId = 00000000-0000-0000-0000-000000000004
@specializationId = 00000000-0000-0000-0000-000000000005

# ─────────────────────────────────────────────────────────────────────────────
# STAFF
# ─────────────────────────────────────────────────────────────────────────────

### Login
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}`nX-Client-Type: mobile

{
  "emailOrUsername": "owner@clinic.com",
  "password": "Password123!"
}

@token = {{login.response.body.$.accessToken}}

# ── Staff list & detail ───────────────────────────────────────────────────────

### Get all staff (paginated)
GET {{baseUrl}}/api/staff?pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Filter by role
GET {{baseUrl}}/api/staff?role=Doctor&pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Filter by active status
GET {{baseUrl}}/api/staff?isActive=true&pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Sort by name
GET {{baseUrl}}/api/staff?sortBy=fullName&sortDirection=asc&pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Get staff detail
GET {{baseUrl}}/api/staff/{{staffId}}
Authorization: Bearer {{token}}

### Activate staff member
# SetStaffActiveStatusRequest: IsActive
PATCH {{baseUrl}}/api/staff/{{staffId}}/active-status
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "isActive": true
}

### Deactivate staff member
PATCH {{baseUrl}}/api/staff/{{staffId}}/active-status
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "isActive": false
}

# ── Invitations ───────────────────────────────────────────────────────────────

### Invite a doctor
# InviteStaffCommand: Role, Email, SpecializationId?
POST {{baseUrl}}/api/staff/invite
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "role": "Doctor",
  "email": "doctor@clinic.com",
  "specializationId": "{{specializationId}}"
}

### Invite a receptionist (no specializationId needed)
POST {{baseUrl}}/api/staff/invite
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "role": "Receptionist",
  "email": "receptionist@clinic.com"
}

### Get all invitations (paginated)
GET {{baseUrl}}/api/staff/invitations?pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Get pending invitations only (status=0)
# InvitationStatus: Pending=0, Accepted=1, Canceled=2, Expired=3
GET {{baseUrl}}/api/staff/invitations?status=0&pageNumber=1&pageSize=10
Authorization: Bearer {{token}}

### Get invitation detail
GET {{baseUrl}}/api/staff/invitations/{{invitationId}}
Authorization: Bearer {{token}}

### Resend invitation (extends expiry by 7 days)
PATCH {{baseUrl}}/api/staff/invitations/{{invitationId}}/resend
Authorization: Bearer {{token}}

### Cancel invitation (state change — not a delete, record is kept)
PATCH {{baseUrl}}/api/staff/invitations/{{invitationId}}/cancel
Authorization: Bearer {{token}}

### Accept invitation with registration (public — no auth)
# AcceptInvitationRequest: FullName, UserName, Password, PhoneNumber, Gender
POST {{baseUrl}}/api/staff/invitations/INVITATION_TOKEN_HERE/accept-with-registration
Content-Type: {{contentType}}

{
  "fullName": "Dr. Sara Ahmed",
  "userName": "sara.ahmed",
  "password": "Password123!",
  "phoneNumber": "+966501234567",
  "gender": "Female"
}

# ── Owner registers as doctor ─────────────────────────────────────────────────

### Set clinic owner as doctor
# SetOwnerAsDoctorRequest: SpecializationId?
PATCH {{baseUrl}}/api/staff/me/doctor-profile
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "specializationId": "{{specializationId}}"
}

# ── Working days ──────────────────────────────────────────────────────────────

### Get working days for a staff member (all branches)
GET {{baseUrl}}/api/staff/{{staffId}}/working-days
Authorization: Bearer {{token}}

### Get working days for a specific branch
GET {{baseUrl}}/api/staff/{{staffId}}/working-days?branchId={{branchId}}
Authorization: Bearer {{token}}

### Save working days
# SaveWorkingDaysRequest: BranchId, Days[]
# WorkingDayRequest: Day (0=Sun…6=Sat), StartTime, EndTime, IsAvailable
PUT {{baseUrl}}/api/staff/{{staffId}}/working-days
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "branchId": "{{branchId}}",
  "days": [
    { "day": 0, "startTime": "09:00", "endTime": "17:00", "isAvailable": false },
    { "day": 1, "startTime": "09:00", "endTime": "17:00", "isAvailable": true },
    { "day": 2, "startTime": "09:00", "endTime": "17:00", "isAvailable": true },
    { "day": 3, "startTime": "09:00", "endTime": "17:00", "isAvailable": true },
    { "day": 4, "startTime": "09:00", "endTime": "17:00", "isAvailable": true },
    { "day": 5, "startTime": "09:00", "endTime": "14:00", "isAvailable": true },
    { "day": 6, "startTime": "09:00", "endTime": "14:00", "isAvailable": false }
  ]
}

# ── Visit types ───────────────────────────────────────────────────────────────

### Get visit types for a doctor at a branch
GET {{baseUrl}}/api/staff/{{staffId}}/visit-types?branchId={{branchId}}
Authorization: Bearer {{token}}

### Add a new visit type
# POST to create — no visitTypeId in body, it's a new resource
POST {{baseUrl}}/api/staff/{{staffId}}/visit-types
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "branchId": "{{branchId}}",
  "name": "Consultation",
  "price": 150,
  "isActive": true
}

### Update an existing visit type
# PUT /{visitTypeId} to update — visitTypeId in URL
PUT {{baseUrl}}/api/staff/{{staffId}}/visit-types/{{visitTypeId}}
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "branchId": "{{branchId}}",
  "name": "Follow-up",
  "price": 80,
  "isActive": true
}

### Deactivate a visit type
PUT {{baseUrl}}/api/staff/{{staffId}}/visit-types/{{visitTypeId}}
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "branchId": "{{branchId}}",
  "name": "Emergency",
  "price": 250,
  "isActive": false
}

### Remove a visit type permanently
DELETE {{baseUrl}}/api/staff/{{staffId}}/visit-types/{{visitTypeId}}
Authorization: Bearer {{token}}

# ── Schedule lock ─────────────────────────────────────────────────────────────

### Allow doctor to self-manage their schedule
# SetDoctorScheduleLockRequest: CanSelfManage
PATCH {{baseUrl}}/api/staff/{{staffId}}/schedule-lock
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "canSelfManage": true
}

### Lock doctor schedule (owner manages it)
PATCH {{baseUrl}}/api/staff/{{staffId}}/schedule-lock
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "canSelfManage": false
}

# ── Permissions ───────────────────────────────────────────────────────────────

### Get staff member permissions
GET {{baseUrl}}/api/staff/{{staffId}}/permissions
Authorization: Bearer {{token}}

### Set staff member permissions (replaces all existing)
# Body: array of permission strings
# Valid values: ViewPatients, CreatePatient, EditPatient, DeletePatient,
#               ViewStaff, InviteStaff, ManageStaffStatus,
#               ViewBranches, ManageBranches,
#               ManageSchedule, ManageVisitTypes,
#               ViewAppointments, ManageAppointments,
#               ViewInvoices, ManageInvoices
PUT {{baseUrl}}/api/staff/{{staffId}}/permissions
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

[
  "ViewPatients",
  "CreatePatient",
  "EditPatient",
  "ViewAppointments",
  "ManageAppointments"
]

### Remove all permissions
PUT {{baseUrl}}/api/staff/{{staffId}}/permissions
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

[]
