{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ClinicManagementDb;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true"
  },
  "Jwt": {
    "Key": "this-is-a-very-long-secret-key-for-jwt-signing-that-is-at-least-32-characters-long-for-security",
    "Issuer": "ClinicManagementAPI",
    "Audience": "ClinicManagementClient",
    "ExpiryInMinutes": 15,
    "RefreshTokenExpiryInDays": 7
  },
  "JwtMiddleware": {
    "ClockSkew": "00:00:00",
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateIssuerSigningKey": true,
    "PublicPaths": [
      "/api/auth/login",
      "/api/auth/register",
      "/api/auth/forgot-password",
      "/api/auth/reset-password",
      "/api/auth/confirm-email",
      "/api/v1.0/reviews/featured",
      "/api/v1.0/reviews/stats",
      "/swagger",
      "/health"
    ],
    "EnableAutoRefresh": true,
    "ClearCookiesOnInvalidToken": true,
    "EnableDetailedLogging": true,
    "RefreshBufferTime": "00:05:00"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "Microsoft.AspNetCore.Server.Kestrel": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/clinic-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Smtp": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UserName": "elemlak202099@gmail.com",
    "Password": "gjsd cgxt blck sjoe",
    "FromName": "Clinic Management System",
    "FromEmail": "elemlak202099@gmail.com",
    "FrontendUrl": "http://localhost:3000"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "Window": 60,
    "QueueLimit": 10
  },
  "FileStorage": {
    "LocalPath": "uploads"
  },
  "AllowedHosts": "*",
  "IsProduction": false,
  "CookieDomain": null
}
