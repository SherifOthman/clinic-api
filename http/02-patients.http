### ============================================================
### PATIENTS
### ============================================================

@baseUrl = http://localhost:5000/api

# @name loginOwner
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "owner@clinic.com",
  "password": "ClinicOwner123!"
}

###

@ownerToken      = {{loginOwner.response.body.accessToken}}

# @name loginSuperAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "superadmin@clinic.com",
  "password": "SuperAdmin123!"
}

###

@superAdminToken = {{loginSuperAdmin.response.body.accessToken}}

# ── Get chronic diseases (needed for create form) ─────────────
GET {{baseUrl}}/chronic-diseases
Authorization: Bearer {{ownerToken}}

###

# ── List patients (paginated) ─────────────────────────────────
GET {{baseUrl}}/patients?pageNumber=1&pageSize=10
Authorization: Bearer {{ownerToken}}

###

# ── List patients with search ─────────────────────────────────
GET {{baseUrl}}/patients?searchTerm=ahmed&pageNumber=1&pageSize=10
Authorization: Bearer {{ownerToken}}

###

# ── List patients with gender filter ─────────────────────────
GET {{baseUrl}}/patients?gender=Female&pageNumber=1&pageSize=10
Authorization: Bearer {{ownerToken}}

###

# ── List patients sorted by name ──────────────────────────────
GET {{baseUrl}}/patients?sortBy=fullName&sortDirection=asc&pageNumber=1&pageSize=10
Authorization: Bearer {{ownerToken}}

###

# ── Create patient ────────────────────────────────────────────
# @name createPatient
POST {{baseUrl}}/patients
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "fullName": "Ahmed Ali Hassan",
  "dateOfBirth": "1990-05-15",
  "gender": "Male",
  "bloodType": "A+",
  "phoneNumbers": ["+966500000001"],
  "chronicDiseaseIds": [],
  "countryGeonameId": null,
  "stateGeonameId": null,
  "cityGeonameId": null
}

###

@patientId = {{createPatient.response.headers.Location.split("/").pop()}}

# ── Get patient detail ────────────────────────────────────────
# Replace PATIENT_ID with a real ID from the create response
GET {{baseUrl}}/patients/PATIENT_ID
Authorization: Bearer {{ownerToken}}

###

# ── Update patient ────────────────────────────────────────────
PUT {{baseUrl}}/patients/PATIENT_ID
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "fullName": "Ahmed Ali Hassan Updated",
  "dateOfBirth": "1990-05-15",
  "gender": "Male",
  "bloodType": "B+",
  "phoneNumbers": ["+966500000001", "+966500000002"],
  "chronicDiseaseIds": [],
  "countryGeonameId": null,
  "stateGeonameId": null,
  "cityGeonameId": null
}

###

# ── Get location options (countries with patients) ────────────
GET {{baseUrl}}/patients/location-options
Authorization: Bearer {{ownerToken}}

###

# ── Get location options (states in a country) ────────────────
GET {{baseUrl}}/patients/location-options?countryGeonameId=357994
Authorization: Bearer {{ownerToken}}

###

# ── Delete patient ────────────────────────────────────────────
DELETE {{baseUrl}}/patients/PATIENT_ID
Authorization: Bearer {{ownerToken}}

###

# ── SuperAdmin: list all patients across clinics ──────────────
GET {{baseUrl}}/patients/all?pageNumber=1&pageSize=10
Authorization: Bearer {{superAdminToken}}

###

# ── SuperAdmin: get patient detail ───────────────────────────
GET {{baseUrl}}/patients/all/PATIENT_ID
Authorization: Bearer {{superAdminToken}}

###

# ── SuperAdmin: restore deleted patient ──────────────────────
PATCH {{baseUrl}}/patients/PATIENT_ID/restore
Authorization: Bearer {{superAdminToken}}

###

# ── ERROR CASES ───────────────────────────────────────────────

# Missing required fields → 400
POST {{baseUrl}}/patients
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "fullName": "",
  "dateOfBirth": "1990-05-15",
  "gender": "Male"
}

###

# Non-existent patient → 404
GET {{baseUrl}}/patients/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{ownerToken}}

###

# No permission (doctor trying to delete) → 403
DELETE {{baseUrl}}/patients/PATIENT_ID
Authorization: Bearer {{loginDoctor.response.body.accessToken}}

###
