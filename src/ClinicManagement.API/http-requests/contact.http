@baseUrl = http://localhost:5000
@contentType = application/json

# Run "Login as SuperAdmin" first — @adminToken is populated from the response
@adminToken = {{loginAdmin.response.body.$.accessToken}}

### Login as SuperAdmin — run this first
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}
X-Client-Type: mobile

{
  "emailOrUsername": "admin@system.com",
  "password": "Password123!"
}

### Submit a contact form message (public — no auth required)
POST {{baseUrl}}/api/contact
Content-Type: {{contentType}}

{
  "firstName": "Ahmed",
  "lastName": "Al-Rashid",
  "email": "ahmed@example.com",
  "phone": "+966501234567",
  "company": "Al-Shifa Clinic",
  "subject": "Pricing inquiry",
  "message": "I would like to know more about your subscription plans."
}

### Submit minimal contact message (no phone or company)
POST {{baseUrl}}/api/contact
Content-Type: {{contentType}}

{
  "firstName": "Sara",
  "lastName": "Mohamed",
  "email": "sara@example.com",
  "subject": "General question",
  "message": "How do I get started with ClinicCare?"
}

### View all contact messages (SuperAdmin only)
GET {{baseUrl}}/api/contact?page=1&pageSize=20
Authorization: Bearer {{adminToken}}
