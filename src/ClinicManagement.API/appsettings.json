{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "ClinicManagement": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/clinic-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Jwt": {
    "Key": "Kj8vN2mQ9rT5wX1zC4bF7hL0pS3uY6eR9tI2oP5aS8dG1jK4nM7qW0zX3cV6bN9m",
    "Issuer": "ClinicManagementAPI",
    "Audience": "ClinicManagementClient",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Cookie": {
    "RefreshTokenExpiryInDays": 30,
    "IsProduction": false
  },
  "GeoNames": {
    "BaseUrl": "https://download.geonames.org/export/dump",
    "CacheDir": "wwwroot/SeedData/GeoNames"
  },
  "FileStorage": {
    "UploadPath": "uploads",
    "BaseUrl": "/uploads",
    "FileTypes": {
      "ProfileImage": {
        "AllowedExtensions": [".jpg", ".jpeg", ".png", ".gif"],
        "MaxFileSizeBytes": 5242880,
        "Folder": "profiles"
      },
      "MedicalFile": {
        "AllowedExtensions": [".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx"],
        "MaxFileSizeBytes": 10485760,
        "Folder": "medical-files"
      }
    }
  },
  "Seed": {
    "SuperAdmin":   { "Email": "superadmin@clinic.com",   "Password": "SuperAdmin123!"   },
    "ClinicOwner":  { "Email": "owner@clinic.com",        "Password": "ClinicOwner123!"  },
    "Doctor":       { "Email": "doctor@clinic.com",       "Password": "Doctor123!"       },
    "Receptionist": { "Email": "receptionist@clinic.com", "Password": "Receptionist123!" }
  },
  "AllowedHosts": "*"
}
