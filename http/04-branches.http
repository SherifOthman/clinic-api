### ============================================================
### BRANCHES
### ============================================================

@baseUrl = http://localhost:5000/api

# @name loginOwner
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "owner@clinic.com",
  "password": "ClinicOwner123!"
}

###

@ownerToken = {{loginOwner.response.body.accessToken}}

# @name loginDoctor
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "doctor@clinic.com",
  "password": "Doctor123!"
}

###

@doctorToken = {{loginDoctor.response.body.accessToken}}

# ── List branches ─────────────────────────────────────────────
GET {{baseUrl}}/branches
Authorization: Bearer {{ownerToken}}

###

# ── Create branch ─────────────────────────────────────────────
# @name createBranch
POST {{baseUrl}}/branches
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "North Branch",
  "addressLine": "456 North Street, Cairo",
  "stateGeonameId": null,
  "cityGeonameId": null,
  "phoneNumbers": ["+20212345678"]
}

###

# ── Update branch ─────────────────────────────────────────────
# Replace BRANCH_ID with a real ID
PUT {{baseUrl}}/branches/BRANCH_ID
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "North Branch Updated",
  "addressLine": "456 North Street, Cairo - Updated",
  "stateGeonameId": null,
  "cityGeonameId": null,
  "phoneNumbers": ["+20212345678", "+20212345679"]
}

###

# ── Deactivate branch ─────────────────────────────────────────
PATCH {{baseUrl}}/branches/BRANCH_ID/active-status
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "isActive": false
}

###

# ── Reactivate branch ─────────────────────────────────────────
PATCH {{baseUrl}}/branches/BRANCH_ID/active-status
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "isActive": true
}

###

# ── ERROR CASES ───────────────────────────────────────────────

# Doctor trying to create branch → 403
POST {{baseUrl}}/branches
Content-Type: application/json
Authorization: Bearer {{doctorToken}}

{
  "name": "Unauthorized Branch",
  "addressLine": "123 Street"
}

###

# Missing required name → 400
POST {{baseUrl}}/branches
Content-Type: application/json
Authorization: Bearer {{ownerToken}}

{
  "name": "",
  "addressLine": "123 Street"
}

###
