@baseUrl = http://localhost:5000
@contentType = application/json

# ─────────────────────────────────────────────────────────────────────────────
# ONBOARDING
# Requires: authenticated ClinicOwner who has NOT yet completed onboarding.
# Get a valid subscriptionPlanId from GET /api/subscription-plans first.
# ─────────────────────────────────────────────────────────────────────────────

### Login as new owner (not yet onboarded)
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "emailOrUsername": "newowner@clinic.com",
  "password": "Password123!"
}

@token = {{login.response.body.$.accessToken}}

### Complete onboarding
# CompleteOnboarding: ClinicName, SubscriptionPlanId, BranchName, AddressLine,
#                     StateGeonameId?, CityGeonameId?, CountryCode?
POST {{baseUrl}}/api/onboarding/complete
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "clinicName": "Al-Shifa Medical Center",
  "subscriptionPlanId": "00000000-0000-0000-0000-000000000001",
  "branchName": "Main Branch",
  "addressLine": "123 King Fahd Road, Riyadh",
  "stateGeonameId": 101628,
  "cityGeonameId": 108410,
  "countryCode": "SA"
}

### Complete onboarding (minimal — no location)
POST {{baseUrl}}/api/onboarding/complete
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "clinicName": "City Clinic",
  "subscriptionPlanId": "00000000-0000-0000-0000-000000000001",
  "branchName": "Main Branch",
  "addressLine": "456 Main Street",
  "stateGeonameId": null,
  "cityGeonameId": null,
  "countryCode": null
}
