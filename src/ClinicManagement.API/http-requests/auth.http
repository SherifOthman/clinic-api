@baseUrl = http://localhost:5000
@contentType = application/json

###
# AUTH — Full flow in order
#
# REGISTRATION FLOW:
#   1. POST /register          → creates account, sends confirmation email
#   2. (user clicks email link) → frontend reads ?userId=...&token=... from URL
#   3. POST /confirm-email     → activates account (userId + token from link)
#   4. POST /login             → get tokens
#   5. POST /onboarding/complete → (ClinicOwner only, first login)
#
# PASSWORD RESET FLOW:
#   1. POST /forgot-password   → sends reset email (always 204, no enumeration)
#   2. (user clicks email link) → frontend reads ?email=...&token=... from URL
#   3. POST /reset-password    → sets new password (email + token from link)
#
# TOKEN REFRESH FLOW (web):
#   - Tokens live in HttpOnly cookies — browser sends them automatically
#   - POST /refresh with no body — reads cookie automatically
#
# TOKEN REFRESH FLOW (mobile):
#   - Tokens returned in response body
#   - POST /refresh with { "refreshToken": "..." } + X-Client-Type: mobile

# ── Step 1: Register ──────────────────────────────────────────────────────────

### Register a new clinic owner
# RegisterCommand: FullName, UserName, Email, Password, Gender, PhoneNumber
# → 201 Created + sends confirmation email
# → 400 if email/username taken or password too weak
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "fullName": "Ahmed Al-Rashid",
  "userName": "ahmed.rashid",
  "email": "elemlak202099@gmail.com",
  "password": "Password123!",
  "gender": "Male",
  "phoneNumber": "+966501234567"
}

# ── Step 2: Confirm email ─────────────────────────────────────────────────────

### Confirm email address
# ConfirmEmailCommand: UserId, Token
# Token comes from the email link: /confirm-email?userId=...&token=...
# → 204 NoContent on success
# → 409 if already confirmed, 401 if token invalid/expired
POST {{baseUrl}}/api/auth/confirm-email
Content-Type: {{contentType}}

{
  "userId": "00000000-0000-0000-0000-000000000001",
  "token": "TOKEN_FROM_EMAIL_LINK"
}

### Resend confirmation email
# ResendEmailVerificationCommand: Email
# → 204 NoContent always (prevents enumeration)
POST {{baseUrl}}/api/auth/resend-email-verification
Content-Type: {{contentType}}

{
  "email": "ahmed@clinic.com"
}

# ── Step 3: Login ─────────────────────────────────────────────────────────────

### Login — web client (tokens set as HttpOnly cookies)
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "emailOrUsername": "elemlak202099@gmail.com",
  "password": "Password123!"
}

@token = {{login.response.body.$.accessToken}}

### Login — mobile client (tokens returned in body)
# @name loginMobile
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}
X-Client-Type: mobile

{
  "emailOrUsername": "elemlak202099@gmail.com",
  "password": "Password123!"
}

@mobileToken = {{loginMobile.response.body.$.accessToken}}

# ── Step 4: Get current user ──────────────────────────────────────────────────

### Get current user profile
# hasPassword=false means Google OAuth user — change-password not available
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{token}}

# ── Token management ──────────────────────────────────────────────────────────

### Refresh token — web (reads HttpOnly cookie, no body needed)
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}

### Refresh token — mobile
POST {{baseUrl}}/api/auth/refresh
Content-Type: {{contentType}}
X-Client-Type: mobile

{
  "refreshToken": "REFRESH_TOKEN_HERE"
}

### Logout — web (clears HttpOnly cookies)
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

### Logout — mobile (revokes refresh token)
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{mobileToken}}
Content-Type: {{contentType}}
X-Client-Type: mobile

{
  "refreshToken": "REFRESH_TOKEN_HERE"
}

# ── Profile management ────────────────────────────────────────────────────────

### Update profile
# UpdateProfileRequest: FullName, UserName, PhoneNumber, Gender
PUT {{baseUrl}}/api/auth/profile
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "fullName": "Ahmed Al-Rashid",
  "userName": "ahmed.rashid",
  "phoneNumber": "+966501234567",
  "gender": "Male"
}

### Delete profile image
DELETE {{baseUrl}}/api/auth/profile/image
Authorization: Bearer {{token}}

# ── Password management ───────────────────────────────────────────────────────

### Change password (only if hasPassword=true from /me)
# ChangePasswordCommand: CurrentPassword, NewPassword
PATCH {{baseUrl}}/api/auth/password
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "currentPassword": "Password123!",
  "newPassword": "NewPassword123!"
}

### Forgot password
# → always 204 regardless of whether email exists (prevents enumeration)
POST {{baseUrl}}/api/auth/forgot-password
Content-Type: {{contentType}}

{
  "email": "elemlak202099@gmail.com"
}

### Reset password
# ResetPasswordCommand: Email, Token, NewPassword
# Token comes from the email link: /reset-password?email=...&token=...
POST {{baseUrl}}/api/auth/reset-password
Content-Type: {{contentType}}

{
  "email": "elemlak202099@gmail.com",
  "token": "TOKEN_FROM_EMAIL_LINK",
  "newPassword": "NewPassword123!"
}

# ── Availability checks ───────────────────────────────────────────────────────

### Check email availability
GET {{baseUrl}}/api/auth/check-email?email=newuser@clinic.com

### Check username availability
GET {{baseUrl}}/api/auth/check-username?username=newuser
