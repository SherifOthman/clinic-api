### ============================================================
### DASHBOARD
### ============================================================

@baseUrl = http://localhost:5000/api

# @name loginOwner
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "owner@clinic.com",
  "password": "ClinicOwner123!"
}

###

@ownerToken = {{loginOwner.response.body.accessToken}}

# @name loginSuperAdmin
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "superadmin@clinic.com",
  "password": "SuperAdmin123!"
}

###

@superAdminToken = {{loginSuperAdmin.response.body.accessToken}}

# @name loginDoctor
POST {{baseUrl}}/auth/login
Content-Type: application/json
X-Client-Type: mobile

{
  "emailOrUsername": "doctor@clinic.com",
  "password": "Doctor123!"
}

###

@doctorToken = {{loginDoctor.response.body.accessToken}}

# ── Clinic staff stats (owner, doctor, receptionist) ─────────
GET {{baseUrl}}/dashboard/stats
Authorization: Bearer {{ownerToken}}

###

# ── Same stats as doctor ──────────────────────────────────────
GET {{baseUrl}}/dashboard/stats
Authorization: Bearer {{doctorToken}}

###

# ── Recent patients (owner only) ──────────────────────────────
GET {{baseUrl}}/dashboard/recent-patients
Authorization: Bearer {{ownerToken}}

###

# ── SuperAdmin stats ──────────────────────────────────────────
GET {{baseUrl}}/dashboard/stats/superadmin
Authorization: Bearer {{superAdminToken}}

###

# ── ERROR CASES ───────────────────────────────────────────────

# Doctor trying to get recent patients → 403
GET {{baseUrl}}/dashboard/recent-patients
Authorization: Bearer {{doctorToken}}

###

# SuperAdmin stats with clinic owner token → 403
GET {{baseUrl}}/dashboard/stats/superadmin
Authorization: Bearer {{ownerToken}}

###
