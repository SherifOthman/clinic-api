@baseUrl = http://localhost:5000
@countryGeonameId = 682730
@stateGeonameId = 101628

# ─────────────────────────────────────────────────────────────────────────────
# LOCATIONS  (all endpoints are anonymous)
# ─────────────────────────────────────────────────────────────────────────────

### Get all countries
GET {{baseUrl}}/api/locations/countries

### Get all states/governorates in a country (e.g. Saudi Arabia = 102358)
GET {{baseUrl}}/api/locations/countries/102358/states

### Get all cities in a state (e.g. Riyadh Region = 101628)
GET {{baseUrl}}/api/locations/states/{{stateGeonameId}}/cities
